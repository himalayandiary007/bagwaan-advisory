# ── Meta WhatsApp Cloud API ───────────────────────────────────────────────────
# Get these from: developers.facebook.com → Your App → WhatsApp → API Setup

META_PHONE_NUMBER_ID=1234567890123456         # 16-digit number from Meta dashboard
META_ACCESS_TOKEN=EAAxxxxxxxxxx               # Temporary token (refresh every 24h) OR permanent system user token
META_VERIFY_TOKEN=bagwaan_webhook_2024        # Any string YOU choose — must match what you enter in Meta dashboard

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Local:   postgresql://localhost:5432/hp_apple_advisory
# Render:  postgresql://user:pass@host/dbname  (Render gives you this string)
DATABASE_URL=postgresql://localhost:5432/hp_apple_advisory

# ── Google Gemini (disease detection from images) ────────────────────────────
# Free tier: 1,500 requests/day, no credit card needed
# Get key at: aistudio.google.com → Get API Key (takes 2 minutes)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key

# ── Tomorrow.io (weather) ─────────────────────────────────────────────────────
# Free tier: 500 calls/day — enough for POC
# Sign up at: tomorrow.io
TOMORROW_API_KEY=your_tomorrow_io_api_key

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
