  "special_protocols": {
    "white_root_rot": {
      "description": "Phytophthora or Rosellinia causing root decay",
      "symptoms": "Sudden wilting, bark at collar turns brown, white fungal threads visible",
      "treatment": [
        "Drench basin area 3–4 times at onset of rainy season to depth 15–20 cm",
        "Carbendazim 0.1% OR Aureofungin (0.05%) + Copper Sulphate (0.05%)",
        "In winters: expose root system to sunlight, remove infected portions, apply Bordeaux paint"
      ]
    },
    "collar_rot": {
      "description": "Phytophthora collar rot near soil line",
      "symptoms": "Reddish-brown bark lesion at collar, gum oozing, crown decline",
      "treatment": [
        "Scarify wounds near collar region",
        "Apply Bordeaux paint or copper fungicide paint during winter",
        "Drench basin 30cm from trunk with Mancozeb 0.3% during rainy season"
      ]
    },
    "hail_damage": {
      "description": "Emergency protocol after hailstorm",
      "steps": [
        {
          "timing": "Immediately",
          "action": "Spray Carbendazim 100 gm OR Mancozeb 600 gm in 200L water"
        },
        {
          "timing": "Within 3–4 days",
          "action": "Spray Boric acid 200 gm + Zinc Sulphate 500 gm + Quick lime 250 gm in 200L water"
        },
        {
          "timing": "10–12 days after hail",
          "action": "Spray micro-nutrients (Agromin / Multiplex / Microvit) 400–600 gm per 200L + Urea 1 kg per 200L"
        }
      ]
    },
    "fruit_size_enhancement": {
      "description": "Gibberellin application to improve L:D ratio",
      "timing": "80–90% king flower bloom stage",
      "treatment": "Gibberellic Acid (GA4+GA7) 1.8% + Benzyladenine (BA) 1.8% @ 277–333 ml per 200 litres water (25–30 ppm)"
    }
  },
  "weather_rules": {
    "global_rules": [
      {
        "rule_id": "rain_repeat",
        "trigger": "rainfall > 5mm within 12 hours of spray application",
        "action": "Push alert: spray was likely washed off — re-spray within 7 days",
        "app_behaviour": "Set reminder 7 days after spray. If rain detected on spray day, fire immediate alert."
      },
      {
        "rule_id": "dodine_temp_lock",
        "trigger": "max_temperature_forecast > 30°C",
        "action": "Remove Dodine 65 WP and Dodine 40% SC from all recommendations for that day",
        "app_behaviour": "Check daily max temp from weather API. Suppress Dodine if threshold met."
      },
      {
        "rule_id": "beneficial_insect_window",
        "trigger": "date between April 1 and June 30",
        "action": "Add advisory note: minimise insecticide sprays — Lady bird beetles, Syrphid flies active",
        "app_behaviour": "Show seasonal banner; push insecticide recommendations to 'last resort' in UI."
      },
      {
        "rule_id": "hail_protocol_trigger",
        "trigger": "hail reported by farmer OR hail forecast confidence > 70%",
        "action": "Push emergency hail protocol notification immediately",
        "app_behaviour": "Alert farmer within 30 minutes of hail detection. Show 3-step hail protocol."
      },
      {
        "rule_id": "scab_infection_window",
        "trigger": "leaf wetness hours >= 9 at temperature 13–24°C (Mills Table)",
        "action": "SCAB INFECTION ALERT: high infection risk. Spray within 24 hours if not done in last 12 days",
        "app_behaviour": "Requires leaf wetness data from API (Tomorrow.io provides this). Critical intelligence — this is the key gap vs. official schedule.",
        "wsu_insight": "WSU: Apple scab management is tightly weather-dependent. HP schedule says 'spray when disease risk' — this rule makes that precise."
      },
      {
        "rule_id": "pre_bloom_frost",
        "trigger": "min_temperature_forecast < 0°C during Pink Bud or Bloom stage",
        "action": "FROST WARNING: blossom damage risk. Do not spray — conserve tree energy.",
        "app_behaviour": "Suppress spray reminders during frost events. Alert farmer to frost protection options."
      },
      {
        "rule_id": "captan_oil_interval",
        "trigger": "HMO (mineral oil) spray logged within last 15 days",
        "action": "Remove all Captan-containing products from recommendations",
        "app_behaviour": "Track spray log. Auto-suppress Captan for 15 days after any logged HMO spray."
      }
    ]
  },
